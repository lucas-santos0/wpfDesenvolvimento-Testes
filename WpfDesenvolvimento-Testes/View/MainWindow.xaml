<Window x:Class="WpfDesenvolvimento_Testes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDesenvolvimento_Testes"
        mc:Ignorable="d"
        Title="Operações com Conjuntos" Height="550" Width="915" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF0A9290" Offset="0.443"/>
                <GradientStop Color="#FF324E4E" Offset="0.993"/>
            </LinearGradientBrush>
        </Grid.Background>
        <!-- Mostrar Conjuntos -->
        <Label Content="Conjunto A: " HorizontalAlignment="Left" Height="27" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Foreground="White"/>
        <Label x:Name="lblConjuntoA" Content=" " HorizontalAlignment="Left" Height="27" Margin="88,10,0,0" VerticalAlignment="Top" Width="672" Background="#FF00535D" Foreground="White"/>
        <Label Content="Conjunto B:" HorizontalAlignment="Left" Height="27" Margin="10,52,0,0" VerticalAlignment="Top" Width="73" Foreground="White"/>
        <Label x:Name="lblConjuntoB" Content=" " HorizontalAlignment="Left" Height="27" Margin="88,52,0,0" VerticalAlignment="Top" Width="672" Background="#FF00535D" Foreground="White"/>
        <!-- Visores -->
        <Label x:Name="lblresultado" Content=" " HorizontalAlignment="Left" Height="27" Margin="10,94,0,0" HorizontalContentAlignment="Center" VerticalAlignment="Top" Width="786" Foreground="White"/>
        <TextBox x:Name="txtVisor" HorizontalAlignment="Left"  HorizontalContentAlignment="Center" Height="36" TextWrapping="Wrap" VerticalAlignment="Top" Width="202" FontSize="20" Margin="326,145,0,0"  BorderBrush="{x:Null}" BorderThickness="2" KeyDown="pressionarBotao" Background="#FF00535D" Foreground="White" />
        <!-- Adicionar -->
        <Label Content="Adicionar ao: " HorizontalAlignment="Left"  HorizontalContentAlignment="Center" Height="27" Margin="326,221,0,0" VerticalAlignment="Top" Width="80" Foreground="White"/>
        <Button x:Name="btnAddConjuntoA" Content="Conjunto A" HorizontalAlignment="Left" Height="28" Margin="323,253,0,0" VerticalAlignment="Top" Width="80" Click="btnAddConjuntoA_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <Button x:Name="btnAddConjuntoB" Content="Conjunto B" HorizontalAlignment="Left" Height="28" Margin="448,253,0,0" VerticalAlignment="Top" Width="80" Click="btnAddConjuntoB_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White"/>
        <!-- Remover -->
        <Label Content="Remover do: " HorizontalAlignment="Left" Height="27" Margin="323,286,0,0" VerticalAlignment="Top" Width="80" Foreground="White"/>
        <Button x:Name="btnRemoverConjuntoA" Content="Conjunto A" HorizontalAlignment="Left" Height="28" Margin="323,319,0,0" VerticalAlignment="Top" Width="80" Click="btnRemoverConjuntoA_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White"/>
        <Button x:Name="btnRemoverConjuntoB" Content="Conjunto B" HorizontalAlignment="Left" Height="28" Margin="448,319,0,0" VerticalAlignment="Top" Width="80" Click="btnRemoverConjuntoB_Click" BorderBrush="{x:Null}" Foreground="White" Background="#FF00535D"/>
        <!-- OPERAÇÕES -->
        <Label Content="Operações: " HorizontalAlignment="Left" Height="27" Margin="323,352,0,0" VerticalAlignment="Top" Width="80" Foreground="White"/>
        <Button x:Name="btnUniao" Content="União" HorizontalAlignment="Left" Height="28" Margin="323,381,0,0" VerticalAlignment="Top" Width="80" Click="btnUniao_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <Button x:Name="btnIntersecao" Content="Interseção" HorizontalAlignment="Left" Height="28" Margin="448,381,0,0" VerticalAlignment="Top" Width="80" Click="btnIntersecao_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <Button x:Name="btnDiferencaAB" Content="A-B" HorizontalAlignment="Left" Height="28" Margin="323,428,0,0" VerticalAlignment="Top" Width="80" Click="btnDiferencaAB_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <Button x:Name="btnDiferencaBA" Content="B-A" HorizontalAlignment="Left" Height="28" Margin="448,428,0,0" VerticalAlignment="Top" Width="80" Click="btnDiferencaBA_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <!-- SubConjuntos -->
        <Button x:Name="btnVerificarSub" Content="Verificar SubConjuntos" HorizontalAlignment="Left" Height="28" Margin="605,225,0,0" VerticalAlignment="Top" Width="132" Click="btnVerificarSub_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White" />
        <!-- Limpar tudo -->
        <Button x:Name="btnLimparTudo" Content="Limpar Tudo" HorizontalAlignment="Left" Height="28" Margin="654,184,0,0" VerticalAlignment="Top" Width="83" Click="btnLimparTudo_Click" BorderBrush="{x:Null}" Foreground="White" Background="#FF00535D"/>
        <!-- Valores Aleatorios -->
        <Label Content="Conjuntos Aleatorios: " HorizontalAlignment="Left" Height="27" Margin="612,313,0,0" VerticalAlignment="Top" Width="125" Foreground="White"/>
        <Label Content="Numero de Elementos(Máx=20): " HorizontalAlignment="Left" Height="27" Margin="584,334,0,0" VerticalAlignment="Top" Width="190" Foreground="White"/>
        <TextBox x:Name="txtAleatorios" HorizontalAlignment="Left" Height="36" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="20" Margin="621,366,0,0"  BorderBrush="{x:Null}" BorderThickness="2" Background="#FF00535D" Foreground="White" />
        <Button x:Name="btnConjuntoAleatorio" Content="Gerar" HorizontalAlignment="Left" Height="28" Margin="633,414,0,0" VerticalAlignment="Top" Width="84" Click="btnConjuntoAleatorio_Click" BorderBrush="{x:Null}" Background="#FF00535D" Foreground="White"/>
        <Label x:Name="lblinstruçao" Content="*separe os termos por &quot;,&quot; ou &quot; &quot;, ou &quot;;&quot;" HorizontalAlignment="Left" Margin="321,185,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Width="212" Foreground="#FFF70000" Background="Transparent">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.573"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>

    </Grid>
</Window>
