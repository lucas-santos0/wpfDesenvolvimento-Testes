<Window x:Class="WpfDesenvolvimento_Testes.WindowTeste"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfDesenvolvimento_Testes"
        mc:Ignorable="d"
        Title="Operações com Conjuntos - Versão de Testes" Height="550" Width="915" WindowStartupLocation="CenterScreen">
    <Grid IsEnabled="True">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF262C33" Offset="0.523"/>
                <GradientStop Color="#FF006530" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <!-- Mostrar Conjuntos -->
        <Label Content="Conjunto A: " HorizontalAlignment="Left" Height="27" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Foreground="#FF00FF04"/>
        <Label x:Name="lblConjuntoA" Content=" " HorizontalAlignment="Left" Height="27" Margin="88,10,0,0" VerticalAlignment="Top" Width="672" Foreground="#FF00FF04"/>
        <Label Content="Conjunto B:" HorizontalAlignment="Left" Height="27" Margin="10,39,0,0" VerticalAlignment="Top" Width="73" Foreground="#FF00FF04"/>
        <Label x:Name="lblConjuntoB" Content=" " HorizontalAlignment="Left" Height="27" Margin="88,39,0,0" VerticalAlignment="Top" Width="672" Foreground="#FF00FF04"/>
        <!-- Visores -->
        <Label x:Name="lblresultado" Content=" " HorizontalAlignment="Center" Height="27" Margin="0,94,0,0" HorizontalContentAlignment="Center" VerticalAlignment="Top" Width="786" Foreground="#FF00FF04"/>
        <TextBox x:Name="txtVisor" HorizontalAlignment="Center"  HorizontalContentAlignment="Center" Height="36" TextWrapping="Wrap" VerticalAlignment="Top" Width="202" FontSize="20" Margin="0,139,0,0"  BorderBrush="{x:Null}" BorderThickness="2" KeyDown="pressionarBotao" Background="Black" Foreground="#FF00FF04" />
        <!-- Adicionar -->
        <Label Content="Adicionar ao: " HorizontalAlignment="Left"  HorizontalContentAlignment="Center" Height="27" Margin="349,184,0,0" VerticalAlignment="Top" Width="80" Foreground="#FF00FF04"/>
        <Button x:Name="btnAddConjuntoA" Content="Conjunto A" HorizontalAlignment="Left" Height="28" Margin="346,216,0,0" VerticalAlignment="Top" Width="80" Click="btnAddConjuntoA_Click" Background="Black" Foreground="#FF00FF04" BorderBrush="{x:Null}" />
        <Button x:Name="btnAddConjuntoB" Content="Conjunto B" HorizontalAlignment="Left" Height="28" Margin="471,216,0,0" VerticalAlignment="Top" Width="80" Click="btnAddConjuntoB_Click" BorderBrush="{x:Null}" Foreground="#FF00FF04" Background="Black"/>
        <!-- Remover -->
        <Label Content="Remover do: " HorizontalAlignment="Left" Height="27" Margin="346,249,0,0" VerticalAlignment="Top" Width="80" Foreground="#FF00FF04"/>
        <Button x:Name="btnRemoverConjuntoA" Content="Conjunto A" HorizontalAlignment="Left" Height="28" Margin="346,282,0,0" VerticalAlignment="Top" Width="80" Click="btnRemoverConjuntoA_Click" Foreground="#FF00FF04" Background="Black" BorderBrush="{x:Null}"/>
        <Button x:Name="btnRemoverConjuntoB" Content="Conjunto B" HorizontalAlignment="Left" Height="28" Margin="471,282,0,0" VerticalAlignment="Top" Width="80" Click="btnRemoverConjuntoB_Click" Foreground="#FF00FF04" BorderBrush="{x:Null}" Background="Black"/>
        <!-- OPERAÇÕES -->
        <Label Content="Operações: " HorizontalAlignment="Left" Height="27" Margin="346,315,0,0" VerticalAlignment="Top" Width="80" Foreground="#FF00FF04"/>
        <Button x:Name="btnUniao" Content="União" HorizontalAlignment="Left" Height="28" Margin="346,344,0,0" VerticalAlignment="Top" Width="80" Click="btnUniao_Click" Foreground="#FF00FF04" Background="Black" BorderBrush="{x:Null}" />
        <Button x:Name="btnIntersecao" Content="Interseção" HorizontalAlignment="Left" Height="28" Margin="471,344,0,0" VerticalAlignment="Top" Width="80" Click="btnIntersecao_Click" Foreground="#FF00FF04" BorderBrush="{x:Null}" Background="Black" />
        <Button x:Name="btnDiferencaAB" Content="A-B" HorizontalAlignment="Left" Height="28" Margin="346,391,0,0" VerticalAlignment="Top" Width="80" Click="btnDiferencaAB_Click" Foreground="#FF00FF04" Background="Black" BorderBrush="{x:Null}" />
        <Button x:Name="btnDiferencaBA" Content="B-A" HorizontalAlignment="Left" Height="28" Margin="471,391,0,0" VerticalAlignment="Top" Width="80" Click="btnDiferencaBA_Click" Foreground="#FF00FF04" BorderBrush="{x:Null}" Background="Black" />
        <!-- SubConjuntos -->
        <Button x:Name="btnVerificarSub" Content="Verificar SubConjuntos" HorizontalAlignment="Left" Height="28" Margin="628,188,0,0" VerticalAlignment="Top" Width="132" Click="btnVerificarSub_Click" BorderBrush="{x:Null}" Foreground="#FF00FF04" Background="Black" />
        <!-- Limpar tudo -->
        <Button x:Name="btnLimparTudo" Content="Limpar Tudo" HorizontalAlignment="Left" Height="28" Margin="677,147,0,0" VerticalAlignment="Top" Width="83" Click="btnLimparTudo_Click" BorderBrush="{x:Null}" Foreground="#FF00FF04" Background="Black"/>
        <!-- Valores Aleatorios -->
        <Label Content="Conjuntos Aleatorios: " HorizontalAlignment="Left" Height="27" Margin="635,276,0,0" VerticalAlignment="Top" Width="125" Foreground="#FF00FF04"/>
        <Label Content="Numero de Elementos(Máx=20): " HorizontalAlignment="Left" Height="27" Margin="607,297,0,0" VerticalAlignment="Top" Width="190" Foreground="#FF00FF04"/>
        <TextBox x:Name="txtAleatorios" HorizontalAlignment="Left" Height="36" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="20" Margin="644,329,0,0"  BorderBrush="{x:Null}" BorderThickness="2" Foreground="#FF00FF04" Background="Black" />
        <Button x:Name="btnConjuntoAleatorio" Content="Gerar" HorizontalAlignment="Left" Height="28" Margin="656,377,0,0" VerticalAlignment="Top" Width="84" Click="btnConjuntoAleatorio_Click" Foreground="#FF00FF04" Background="Black" BorderBrush="{x:Null}"/>
        <!-- Comando Basicos -->
        <Label Content="Comandos Para Teste de Operações:" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="35" Margin="10,188,0,0" VerticalAlignment="Top" Width="273" BorderThickness="2" Foreground="White" FontSize="16"/>

        <Label Content="/tpOff  = Sair do Modo de Testes" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,222,0,0" VerticalAlignment="Top" Width="190" BorderThickness="2" Foreground="#FF00FF04"/>
        <Label Content="/tCriacao  = Testa a Criação/Adição" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,253,0,0" VerticalAlignment="Top" Width="205" BorderThickness="2" Foreground="#FF00FF04"/>
        <Label Content="/tRemocao = Testa a Remoção" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,284,0,0" VerticalAlignment="Top" Width="182" BorderThickness="2" Foreground="#FF00FF04"/>
        <Label Content="/tUniao = Testa a União" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,316,0,0" VerticalAlignment="Top" Width="160" BorderThickness="2" Foreground="#FF00FF04"/>
        <Label Content="/tInterseccao = Testa a Intersecção" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,348,0,0" VerticalAlignment="Top" Width="190"  Foreground="#FF00FF04" BorderThickness="2"/>
        <Label Content="/tDiferenca = Testa a Diferença" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,380,0,0" VerticalAlignment="Top" Width="172" Foreground="#FF00FF04" BorderThickness="2"/>
        <Label Content="/tSubconjunto = Testa a existencia de Subconjuntos: " HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,413,0,0" VerticalAlignment="Top" Width="284" Foreground="#FF00FF04" BorderThickness="2"/>
        <Label Content="/tFullTest =  Faz a Execução de Todos os Testes" HorizontalAlignment="Left"  HorizontalContentAlignment="Left" Height="30" Margin="10,444,0,0" VerticalAlignment="Top" Width="254"  Foreground="#FF00FF04" BorderThickness="2"/>



    </Grid>
</Window>
